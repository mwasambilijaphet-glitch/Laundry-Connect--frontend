# ============================================================
# LAUNDRY CONNECT — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!
# ============================================================

# Database (PostgreSQL / Supabase)
DATABASE_URL=postgresql://user:password@host:5432/database

# JWT Authentication (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Snippe Payment Gateway (https://docs.snippe.sh)
SNIPPE_API_KEY=snp_your_api_key_here
SNIPPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email (Gmail SMTP for password reset)
# 1. Enable 2FA on your Google account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Paste the 16-character password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Briq.tz — SMS & WhatsApp OTP (https://briq.tz)
# No Twilio or Meta needed! Briq handles SMS & WhatsApp natively.
BRIQ_API_KEY=your_briq_api_key_here
BRIQ_API_URL=https://api.briq.tz/v1
BRIQ_SENDER_ID=LaundryConnect

# App URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
PORT=5000

# Node Environment
NODE_ENV=development

# Admin (seeded on first run)
ADMIN_EMAIL=admin@laundryconnect.co.tz
ADMIN_PHONE=0700000000
ADMIN_PASSWORD=ChangeThisSecurePassword123!

# Platform Settings (0.005 = 0.5% commission)
PLATFORM_COMMISSION_RATE=0.005
